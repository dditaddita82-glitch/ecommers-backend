# ─── DATABASE ─────────────────────────────────
DATABASE_URL="postgresql://postgres:bagas@localhost:5432/kosmetik_db"

# ─── JWT ──────────────────────────────────────
JWT_ACCESS_SECRET="change-this-to-a-random-32-char-string-access"
JWT_REFRESH_SECRET="change-this-to-a-random-32-char-string-refresh"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ─── SERVER ───────────────────────────────────
PORT=5000
NODE_ENV="development"

# ─── CORS ─────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
